# ─────────────────────────────────────────────
# Anajbeauty – Environment Variables
# Copy this file to .env.local for local dev
# Add these to Vercel → Project → Settings → Environment Variables
# ─────────────────────────────────────────────

# ── Resend (Email) ───────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The email address Resend is verified to send FROM
RESEND_FROM_EMAIL=contact@anajbeauty.com
# Where contact form submissions are delivered
RESEND_TO_EMAIL=info@anajbeauty.com

# ── Contentful (CMS / Blog) ──────────────────
# Get from https://app.contentful.com → Space Settings → API Keys
CONTENTFUL_SPACE_ID=xxxxxxxxxxxxxxxx
CONTENTFUL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Preview token for draft content
CONTENTFUL_PREVIEW_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret for on-demand ISR revalidation webhook
CONTENTFUL_REVALIDATE_SECRET=your-secret-string-here

# ── Instagram (Feed) ─────────────────────────
# Get from https://developers.facebook.com → Instagram Graph API → Long-lived token
# Note: Long-lived tokens expire after 60 days — set up a refresh cron job
INSTAGRAM_ACCESS_TOKEN=IGQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Site Config ──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://anajbeauty.com
